{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "sandbox": true
    }
  },
  "github": {
    "silent": true,
    "autoJobCancelation": true
  },
  "crons": [
    {
      "path": "/api/cron/send-24-hours-notice-emails",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/send-live-emails",
      "schedule": "0 * * * *"
    }
  ]
}